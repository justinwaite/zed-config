  {
    "context": "VimControl && (Editor && mode == full)",
    "bindings": {
      "-": "pane::RevealInProjectPanel",
    },
  },
  {
    "context": "Editor && VimControl",
    "bindings": {
      "space f": "editor::Format",
    },
  },
  {
    "context": "Workspace && vim_mode != insert",
    "bindings": {
      "space space": [
        "tab_switcher::Toggle",
        {
          "select_last": true,
        },
      ],
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space c a": "editor::ToggleCodeActions",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space a": null,
    },
  },
  {
    "context": "VimControl",
    "bindings": {
      "space r n": "editor::Rename",
    },
  },
  {
    "context": "VimControl",
    "bindings": {
      "space h p": "editor::ToggleHunkDiff"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-up": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-down": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-left": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-right": null
    }
  },
  {
    "context": "(VimControl && !menu) || Terminal",
    "bindings": {
      "ctrl-shift-up": "vim::ResizePaneUp"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "ctrl-w +": null
