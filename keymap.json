    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "ctrl-w -": null
    }
  },
  {
    "context": "(VimControl && !menu) || Terminal",
    "bindings": {
      "ctrl-shift-left": "vim::ResizePaneLeft"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "ctrl-w <": null
    }
  },
  {
    "context": "(VimControl && !menu) || Terminal",
    "bindings": {
      "ctrl-shift-right": "vim::ResizePaneRight"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "ctrl-w >": null
    }
